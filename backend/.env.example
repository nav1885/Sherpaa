# Sherpaa Backend — copy to .env and fill in values

# Strava API credentials from strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Sign JWTs with this secret — generate with: openssl rand -hex 32
JWT_SECRET=

# Server config (Railway injects PORT automatically)
PORT=3000
HOST=0.0.0.0
