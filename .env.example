# Sherpaa App Environment Variables
# Copy this to .env and fill in values. Never commit .env to git.

# Strava OAuth (client_id only — client_secret lives in backend/.env)
EXPO_PUBLIC_STRAVA_CLIENT_ID=

# Backend API
EXPO_PUBLIC_API_URL=https://your-railway-url.railway.app

# RevenueCat (public key only - safe to include in app)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# Google Maps (Android only)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
